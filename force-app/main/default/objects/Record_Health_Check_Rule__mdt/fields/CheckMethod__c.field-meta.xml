<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CheckMethod__c</fullName>
    <label>Check Method</label>
    <description
  >How this check decides pass or fail. Pick one, then fill in only the matching section of fields below.</description>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Formula</fullName>
                <default>false</default>
                <label>Record formula</label>
            </value>
            <value>
                <fullName>Query</fullName>
                <default>false</default>
                <label>Single query</label>
            </value>
            <value>
                <fullName>CompareTwoQueries</fullName>
                <default>false</default>
                <label>Compare two queries</label>
            </value>
            <value>
                <fullName>Apex</fullName>
                <default>false</default>
                <label>Custom Apex</label>
            </value>
        </valueSetDefinition>
    </valueSet>
        <inlineHelpText
  >Record formula = a true/false formula on the record. Single query = run one SOQL and compare the result. Compare two queries = compare two SOQL results. Custom Apex = run your own Apex class.</inlineHelpText>
    <required>true</required>
</CustomField>
