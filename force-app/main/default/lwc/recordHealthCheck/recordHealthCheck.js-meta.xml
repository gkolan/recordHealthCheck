<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <!--
        Record page only. The component requires a record context (recordId) to
        evaluate checks; App/Home pages provide none, so lightning__AppPage was
        removed to prevent a permanently-erroring component placement.
    -->
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property
        name="configName"
        type="String"
        label="Check Set Developer Name"
        description="Developer name of the Record_Health_Check_Set__mdt record to run (e.g. Account_Data_Quality)."
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
