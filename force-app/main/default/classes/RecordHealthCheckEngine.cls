public with sharing class RecordHealthCheckEngine {
  // Compiled once per transaction — reused across all collectRecordFields and applicability calls
  private static final Pattern PATTERN_TOKEN = Pattern.compile(
    '\\{!([A-Za-z0-9_\\.]+)\\}'
  );
  private static final Pattern PATTERN_DOT_PATH = Pattern.compile(
    '\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]+)+)\\b'
  );
  private static final Pattern PATTERN_WORD = Pattern.compile(
    '\\b[A-Za-z_][A-Za-z0-9_]*\\b'
  );
  // SCAN-36: GROUP BY / aggregate detection lives in RecordHealthCheckSoqlTemplate
  // (the single SOQL-shape authority); the local patterns here were dead.

  @TestVisible
  private RecordHealthCheckConfigService configService = new RecordHealthCheckConfigService();
  private RecordHealthCheckFormulaEvaluator formulaEvaluator = new RecordHealthCheckFormulaEvaluator();
  private RecordHealthCheckSoqlEvaluator soqlEvaluator = new RecordHealthCheckSoqlEvaluator();
  private RecordHealthCheckDualSoqlEvaluator dualSoqlEvaluator = new RecordHealthCheckDualSoqlEvaluator();
  private RecordHealthCheckApexEvaluatorDispatcher apexDispatcher = new RecordHealthCheckApexEvaluatorDispatcher();
  @TestVisible
  private static Map<String, RecordHealthCheckResult> transactionResultCache = new Map<String, RecordHealthCheckResult>();
  @TestVisible
  private RecordHealthCheckResult validationResultOverride;

  /**
   * Routes a single check to the correct evaluator and returns exactly one
   * RecordHealthCheckResult. Catchable failures become result statuses; Apex
   * governor-limit exceptions remain uncatchable platform behavior.
   *
   * configName is required and is used server-side to confirm the rule belongs
   * to the named Check Set and that the Check Set is active, preventing a caller
   * from evaluating arbitrary or inactive rules by DeveloperName alone.
   */
  public RecordHealthCheckResult evaluate(
    String configName,
    String checkDeveloperName,
    Id recordId
  ) {
    return evaluate(configName, checkDeveloperName, recordId, null);
  }

  /**
   * RECONCILIATION STOPGAP: matches the facade's 5-arg call signature so the org
   * compiles again. `onBehalfOfUserId` (F-07) is a LOG TAG ONLY and is already
   * recorded by the facade's run() logging, so this overload delegates to the
   * 4-arg evaluate. Replace with the canonical onBehalfOfUserId implementation
   * once this workspace is reconciled with the org's (newer) version.
   */
  public RecordHealthCheckResult evaluate(
    String configName,
    String checkDeveloperName,
    Id recordId,
    String runId,
    Id onBehalfOfUserId
  ) {
    return evaluate(configName, checkDeveloperName, recordId, runId);
  }

  /**
   * runId is a correlation id generated by the LWC (one per page load / run) and
   * threaded through so every log line for this user interaction shares a key.
   * All logging routes through RecordHealthCheckLogger, which also stamps the
   * running user id on each line.
   */
  public RecordHealthCheckResult evaluate(
    String configName,
    String checkDeveloperName,
    Id recordId,
    String runId
  ) {
    runId = RecordHealthCheckLogger.normalizeIdentifier(runId, 120);
    configName = RecordHealthCheckLogger.normalizeIdentifier(configName, 80);
    checkDeveloperName = RecordHealthCheckLogger.normalizeIdentifier(
      checkDeveloperName,
      80
    );
    RecordHealthCheckLogger logger = new RecordHealthCheckLogger(
      runId,
      configName,
      recordId
    );
    Long startMs = System.currentTimeMillis();

    // RB-07: do NOT reset the FormulaEval budget here. Salesforce's 100-call
    // FormulaEval limit is transaction-wide and only clears at the end of the
    // Apex transaction — not per check. Resetting a framework counter per check
    // made the guard lie: in any caller that loops evaluate() in one transaction
    // (Flow, batch, anonymous Apex), the framework count returned to zero while
    // the real platform count kept climbing, so the guard could green-light the
    // call that hits the uncatchable governor limit. The counter is now allowed
    // to accumulate across the whole transaction, matching the platform.

    RecordHealthCheckResult result = new RecordHealthCheckResult();
    result.checkDeveloperName = checkDeveloperName;

    try {
      if (recordId == null) {
        result.status = 'UNABLE_TO_EVALUATE';
        result.reasonCode = 'NO_RECORD_CONTEXT';
        result.message = 'A record id is required to evaluate this check.';
        logger.warn(checkDeveloperName, 'NO_RECORD_CONTEXT', null);
      } else {
        result = doEvaluate(
          configName,
          checkDeveloperName,
          recordId,
          new Set<String>(),
          logger
        );
      }
    } catch (Exception ex) {
      result.status = 'ERROR';
      result.reasonCode = 'APEX_EVALUATOR_ERROR';
      result.message = 'An unexpected error occurred. Contact your administrator.';
      result.detailMessage = ex.getMessage();
      logger.error(checkDeveloperName, 'UNHANDLED_EXCEPTION', null, ex);
    }

    if (result.durationMs == null) {
      result.durationMs = System.currentTimeMillis() - startMs;
    }

    // P1-01: the result cache exists ONLY to memoize a shared prerequisite within
    // a single top-level evaluation (dependency recursion in doEvaluate). Clearing
    // it here, once the top-level evaluation has finished, means a later
    // run()/evaluate() in the same Apex transaction (Flow, batch, anonymous Apex)
    // starts fresh instead of returning this run's stale status/values. Memoization
    // within the call is untouched, and the LWC is unaffected (each evaluateCheck
    // is its own tx).
    transactionResultCache.clear();

    return result;
  }

  // ─── Core routing ─────────────────────────────────────────────────────────

  @TestVisible
  private RecordHealthCheckResult doEvaluate(
    String configName,
    String checkDeveloperName,
    Id recordId,
    Set<String> visitedChain,
    RecordHealthCheckLogger logger
  ) {
    String cacheKey =
      configName +
      '|' +
      String.valueOf(recordId) +
      '|' +
      checkDeveloperName;
    if (transactionResultCache.containsKey(cacheKey)) {
      return copyResult(transactionResultCache.get(cacheKey));
    }
    RecordHealthCheckResult result = doEvaluateUncached(
      configName,
      checkDeveloperName,
      recordId,
      visitedChain,
      logger
    );
    transactionResultCache.put(cacheKey, copyResult(result));
    return result;
  }

  private RecordHealthCheckResult copyResult(RecordHealthCheckResult source) {
    RecordHealthCheckResult copy = new RecordHealthCheckResult();
    copy.checkDeveloperName = source.checkDeveloperName;
    copy.label = source.label;
    copy.status = source.status;
    copy.severity = source.severity;
    copy.message = source.message;
    copy.actualValue = source.actualValue;
    copy.expectedValue = source.expectedValue;
    copy.detailMessage = source.detailMessage;
    copy.adminDetailMessage = source.adminDetailMessage;
    copy.reasonCode = source.reasonCode;
    copy.priority = source.priority;
    copy.durationMs = source.durationMs;
    copy.evaluatorType = source.evaluatorType;
    return copy;
  }

  private RecordHealthCheckResult doEvaluateUncached(
    String configName,
    String checkDeveloperName,
    Id recordId,
    Set<String> visitedChain,
    RecordHealthCheckLogger logger
  ) {
    Boolean debugMode = false;

    // 1. Load rule — scoped to the named Check Set and must be active.
    //    Returns null when rule is missing, inactive, or belongs to a different set,
    //    preventing evaluation of unauthorized rules via direct Apex invocation.
    Record_Health_Check_Rule__mdt rule = configService.loadRule(
      checkDeveloperName,
      configName
    );
    if (rule == null) {
      logger.warn(checkDeveloperName, 'CONFIG_NOT_FOUND', null);
      RecordHealthCheckResult r = new RecordHealthCheckResult();
      r.checkDeveloperName = checkDeveloperName;
      r.status = 'UNABLE_TO_EVALUATE';
      r.reasonCode = 'CONFIG_NOT_FOUND';
      r.message = 'Check configuration not found. Contact your administrator.';
      return r;
    }

    // 1a. Validate the parent Check Set is still active and targets the right object.
    //     Also extract DebugMode__c for this run.
    SObject checkSetRef = rule.getSObject('Record_Health_Check_Set__r');
    CheckSetContextOutcome checkSetOutcome = validateCheckSetContext(
      checkSetRef,
      configName,
      checkDeveloperName,
      recordId
    );
    debugMode = checkSetOutcome.debugMode;
    if (checkSetOutcome.result != null) {
      // CONFIG_INACTIVE or OBJECT_MISMATCH — surfaced here so all logging stays
      // in one layer (validateCheckSetContext itself does not log).
      logger.warn(
        checkDeveloperName,
        'CHECK_SET_CONTEXT_INVALID',
        new Map<String, Object>{
          'reasonCode' => checkSetOutcome.result.reasonCode
        }
      );
      return checkSetOutcome.result;
    }

    logger.debug(
      checkDeveloperName,
      'START',
      new Map<String, Object>{
        'type' => rule.CheckMethod__c,
        'debugMode' => debugMode
      }
    );

    // 1b. B2 fix: server-side RequiresCheck__c gate — mirrors LWC client-side logic
    if (String.isNotBlank(rule.RequiresCheck__c)) {
      String prereqName = rule.RequiresCheck__c.trim();
      if (visitedChain.contains(prereqName)) {
        RecordHealthCheckResult r = new RecordHealthCheckResult();
        r.checkDeveloperName = checkDeveloperName;
        r.label = rule.CheckName__c;
        r.priority = rule.RunOrder__c;
        r.status = 'UNABLE_TO_EVALUATE';
        r.reasonCode = 'CIRCULAR_DEPENDENCY';
        r.message = 'This check has a circular dependency and cannot be evaluated.';
        return applyCheckSetFlags(r, debugMode);
      }
      Set<String> nextVisited = new Set<String>(visitedChain);
      nextVisited.add(checkDeveloperName);
      RecordHealthCheckResult prereqResult = doEvaluate(
        configName,
        prereqName,
        recordId,
        nextVisited,
        logger
      );
      if (prereqResult.status != 'PASS') {
        if (prereqResult.reasonCode == 'CIRCULAR_DEPENDENCY') {
          RecordHealthCheckResult circular = new RecordHealthCheckResult();
          circular.checkDeveloperName = checkDeveloperName;
          circular.label = rule.CheckName__c;
          circular.priority = rule.RunOrder__c;
          circular.status = 'UNABLE_TO_EVALUATE';
          circular.reasonCode = 'CIRCULAR_DEPENDENCY';
          circular.message = 'This check has a circular dependency and cannot be evaluated.';
          return applyCheckSetFlags(circular, debugMode);
        }
        logger.debug(
          checkDeveloperName,
          'DEPENDENCY_NOT_PASSED',
          new Map<String, Object>{
            'prereq' => prereqName,
            'prereqStatus' => prereqResult.status
          }
        );
        RecordHealthCheckResult r = new RecordHealthCheckResult();
        r.checkDeveloperName = checkDeveloperName;
        r.label = rule.CheckName__c;
        r.priority = rule.RunOrder__c;
        r.status = 'SKIPPED';
        r.reasonCode = 'DEPENDENCY_NOT_PASSED';
        r.message = 'This check was skipped because a required check did not pass.';
        return applyCheckSetFlags(r, debugMode);
      }
    }

    // 2. Runtime metadata validation
    RecordHealthCheckResult validationResult = validationResultOverride != null
      ? validationResultOverride
      : configService.validateRuleForEvaluation(rule);
    if (validationResult != null) {
      logger.warn(
        checkDeveloperName,
        'METADATA_INVALID',
        new Map<String, Object>{
          'reasonCode' => validationResult.reasonCode,
          'detail' => validationResult.detailMessage
        }
      );
      return applyCheckSetFlags(validationResult, debugMode);
    }

    // 3. Load the base record (WITH USER_MODE enforces FLS for the running user).
    SObject record;
    try {
      record = loadRecord(recordId, rule);
    } catch (Exception ex) {
      logger.warn(
        checkDeveloperName,
        'RECORD_NOT_ACCESSIBLE',
        new Map<String, Object>{ 'detail' => ex.getMessage() }
      );
      RecordHealthCheckResult r = new RecordHealthCheckResult();
      r.checkDeveloperName = checkDeveloperName;
      r.label = rule.CheckName__c;
      r.priority = rule.RunOrder__c;
      r.status = 'UNABLE_TO_EVALUATE';
      r.reasonCode = 'RECORD_NOT_ACCESSIBLE';
      r.message = 'The record could not be accessed. Contact your administrator.';
      r.detailMessage = ex.getMessage();
      return applyCheckSetFlags(r, debugMode);
    }
    if (record == null) {
      logger.warn(
        checkDeveloperName,
        'RECORD_NOT_ACCESSIBLE',
        new Map<String, Object>{ 'detail' => 'query returned no rows' }
      );
      RecordHealthCheckResult r = new RecordHealthCheckResult();
      r.checkDeveloperName = checkDeveloperName;
      r.label = rule.CheckName__c;
      r.priority = rule.RunOrder__c;
      r.status = 'UNABLE_TO_EVALUATE';
      r.reasonCode = 'RECORD_NOT_ACCESSIBLE';
      r.message = 'The record could not be accessed. Contact your administrator.';
      return applyCheckSetFlags(r, debugMode);
    }

    // 4. Applicability gate (server-side, runs before every evaluator)
    RecordHealthCheckResult applicabilityResult = checkApplicability(
      rule,
      recordId,
      record
    );
    if (applicabilityResult != null) {
      logger.debug(
        checkDeveloperName,
        'APPLICABILITY_GATE',
        new Map<String, Object>{
          'status' => applicabilityResult.status,
          'reasonCode' => applicabilityResult.reasonCode
        }
      );
      // An applicability skip / unable result may carry a MessageWhenCannotRun__c
      // template with {!FieldName} tokens; resolve them here too (the record is
      // already loaded) so tokens never reach the UI.
      resolveResultMessage(applicabilityResult, record);
      return applyCheckSetFlags(applicabilityResult, debugMode);
    }

    logger.debug(
      checkDeveloperName,
      'APPLICABILITY_PASS',
      new Map<String, Object>{ 'mode' => rule.RunThisCheckWhen__c }
    );

    // 5. Route to evaluator
    RecordHealthCheckResult evalResult = routeEvaluator(rule, recordId, record);

    // 6. Resolve merge fields in result messages (S55 — bad token must not change status).
    //    FAIL re-derives its message from MessageWhenFailed__c; every other non-PASS
    //    status (UNABLE_TO_EVALUATE / ERROR / SKIPPED) carries a
    //    MessageWhenCannotRun__c or skip template the evaluator already placed on
    //    the result. Both can contain {!FieldName} tokens, so a token like {!Name}
    //    must never reach the UI for any check type (Query, CompareTwoQueries,
    //    Apex, Formula).
    if (
      evalResult.status == 'FAIL' &&
      String.isNotBlank(rule.MessageWhenFailed__c)
    ) {
      evalResult.message = formulaEvaluator.resolveMergeFields(
        rule.MessageWhenFailed__c,
        record
      );
    } else {
      resolveResultMessage(evalResult, record);
    }

    // 7. Result logging (severity-mapped) and adminDetailMessage propagation.
    //    PASS/SKIPPED are routine (DEBUG); FAIL is noteworthy (INFO); anything
    //    else (UNABLE_TO_EVALUATE/ERROR) is a problem worth surfacing (WARN).
    Map<String, Object> resultFields = new Map<String, Object>{
      'status' => evalResult.status,
      'severity' => evalResult.severity,
      'reasonCode' => evalResult.reasonCode,
      'durationMs' => evalResult.durationMs
    };
    if (String.isNotBlank(evalResult.detailMessage)) {
      resultFields.put('detail', evalResult.detailMessage);
    }
    if (evalResult.status == 'PASS' || evalResult.status == 'SKIPPED') {
      logger.debug(checkDeveloperName, 'RESULT', resultFields);
    } else if (evalResult.status == 'FAIL') {
      logger.info(checkDeveloperName, 'RESULT', resultFields);
    } else {
      logger.warn(checkDeveloperName, 'RESULT', resultFields);
    }

    return applyCheckSetFlags(evalResult, debugMode);
  }

  // Copies detailMessage → adminDetailMessage when debug mode is on so the LWC
  // can surface it to admins without ever exposing raw internals in production.
  @TestVisible
  private RecordHealthCheckResult applyDebugMode(
    RecordHealthCheckResult result,
    Boolean debugMode
  ) {
    if (
      debugMode &&
      RecordHealthCheckAccess.canViewDebugDetails() &&
      String.isNotBlank(result.detailMessage)
    ) {
      result.adminDetailMessage = result.detailMessage;
    } else {
      result.adminDetailMessage = null;
    }
    return result;
  }

  private RecordHealthCheckResult applyCheckSetFlags(
    RecordHealthCheckResult result,
    Boolean debugMode
  ) {
    return applyDebugMode(result, debugMode);
  }

  @TestVisible
  private RecordHealthCheckResult routeEvaluator(
    Record_Health_Check_Rule__mdt rule,
    Id recordId,
    SObject record
  ) {
    if (rule.CheckMethod__c == 'Formula') {
      return formulaEvaluator.evaluate(rule, recordId, record);
    }
    if (rule.CheckMethod__c == 'Query') {
      return soqlEvaluator.evaluate(rule, recordId, record);
    }
    if (rule.CheckMethod__c == 'Apex') {
      return apexDispatcher.evaluate(rule, recordId, record);
    }
    if (rule.CheckMethod__c == 'CompareTwoQueries') {
      return dualSoqlEvaluator.evaluate(rule, recordId, record);
    }

    // Unrecognized — config service should have caught this, but guard defensively
    RecordHealthCheckResult result = new RecordHealthCheckResult();
    result.checkDeveloperName = rule.DeveloperName;
    result.label = rule.CheckName__c;
    result.priority = rule.RunOrder__c;
    result.status = 'UNABLE_TO_EVALUATE';
    result.reasonCode = 'INVALID_CHECK_TYPE';
    result.message = 'This Check Method is not recognized.';
    return result;
  }

  // ─── Applicability gate (Section 3.5) ────────────────────────────────────

  @TestVisible
  private class CheckSetContextOutcome {
    public Boolean debugMode = false;
    public RecordHealthCheckResult result;
  }

  @TestVisible
  private CheckSetContextOutcome validateCheckSetContext(
    SObject checkSetRef,
    String configName,
    String checkDeveloperName,
    Id recordId
  ) {
    CheckSetContextOutcome outcome = new CheckSetContextOutcome();
    if (checkSetRef == null) {
      // SCAN-05: a null Check Set relationship must NOT proceed as if the set were
      // active and object-matched (that would bypass IsActive__c / ObjectApiName__c
      // enforcement). loadRule only returns a rule whose set relationship is
      // populated, so reaching here is an anomaly — surface it as a config error.
      RecordHealthCheckResult result = new RecordHealthCheckResult();
      result.checkDeveloperName = checkDeveloperName;
      result.status = 'UNABLE_TO_EVALUATE';
      result.reasonCode = 'CONFIG_NOT_FOUND';
      result.message = 'The health check configuration could not be loaded.';
      outcome.result = result;
      return outcome;
    }

    outcome.debugMode = checkSetRef.get('DebugMode__c') == true;
    if (checkSetRef.get('IsActive__c') == false) {
      // Logged by the caller (doEvaluate) so all logging lives in one layer.
      RecordHealthCheckResult result = new RecordHealthCheckResult();
      result.checkDeveloperName = checkDeveloperName;
      result.status = 'UNABLE_TO_EVALUATE';
      result.reasonCode = 'CONFIG_INACTIVE';
      result.message = 'The health check configuration is inactive.';
      outcome.result = result;
      return outcome;
    }

    String baseObj = (String) checkSetRef.get('ObjectApiName__c');
    String recordObj = recordId.getSObjectType().getDescribe().getName();
    if (String.isNotBlank(baseObj) && !recordObj.equalsIgnoreCase(baseObj)) {
      // Logged by the caller (doEvaluate) so all logging lives in one layer.
      RecordHealthCheckResult result = new RecordHealthCheckResult();
      result.checkDeveloperName = checkDeveloperName;
      result.status = 'UNABLE_TO_EVALUATE';
      result.reasonCode = 'OBJECT_MISMATCH';
      result.message = 'Record type does not match the health check configuration.';
      outcome.result = result;
    }
    return outcome;
  }

  /**
   * Returns null if the check should proceed.
   * Returns a SKIPPED result if the gate evaluates false.
   * Returns an UNABLE_TO_EVALUATE result if the gate cannot be safely evaluated.
   */
  @TestVisible
  private RecordHealthCheckResult checkApplicability(
    Record_Health_Check_Rule__mdt rule,
    Id recordId,
    SObject record
  ) {
    if (
      rule.RunThisCheckWhen__c == 'Always' ||
      rule.RunThisCheckWhen__c == null
    ) {
      return null;
    }

    if (rule.RunThisCheckWhen__c == 'Formula') {
      String[] reasonCodeOut = new List<String>{ '' };
      Boolean applies = formulaEvaluator.evaluateApplicabilityFormula(
        rule.RunWhenFormula__c,
        record,
        reasonCodeOut
      );

      if (applies == null) {
        return buildUnableResult(
          rule,
          reasonCodeOut[0],
          'The applicability condition could not be evaluated.'
        );
      }
      if (!applies) {
        return buildSkippedResult(rule);
      }
      return null;
    }

    if (rule.RunThisCheckWhen__c == 'SOQL') {
      return checkSoqlApplicability(rule, record);
    }

    return buildUnableResult(
      rule,
      'INVALID_CONFIG',
      'Unrecognized Applicability Mode: ' + rule.RunThisCheckWhen__c
    );
  }

  @TestVisible
  private RecordHealthCheckResult checkSoqlApplicability(
    Record_Health_Check_Rule__mdt rule,
    SObject record
  ) {
    if (String.isBlank(rule.RunWhenCountQuery__c)) {
      return buildUnableResult(
        rule,
        'INVALID_SOQL_TEMPLATE',
        'Applicability SOQL is required when Applicability Mode is SOQL.'
      );
    }

    try {
      String boundSoql = soqlEvaluator.bindTokens(
        rule.RunWhenCountQuery__c,
        record
      );
      if (!RecordHealthCheckSoqlTemplate.isScalarCountQuery(boundSoql)) {
        return buildUnableResult(
          rule,
          'INVALID_SOQL_TEMPLATE',
          'Applicability SOQL must be one scalar COUNT() or COUNT(Id) query without GROUP BY.'
        );
      }
      if (rule.CountThreshold__c == null) {
        return buildUnableResult(
          rule,
          'INVALID_CONFIG',
          'Applicability Comparison Value is required for SOQL applicability.'
        );
      }

      String safeSoql = RecordHealthCheckSoqlTemplate.prepareForExecution(
        boundSoql,
        1
      );
      List<SObject> rows = Database.query(safeSoql);

      Integer count;
      if (!rows.isEmpty() && rows[0] instanceof AggregateResult) {
        // COUNT(Id) / COUNT() with no alias → expr0. Named aliases (e.g. COUNT(Id) mycount)
        // return null for expr0 — surface a clear config error rather than silently treating as 0.
        // B9 fix: accept any alias by looking up the first populated field rather
        // than hardcoding 'expr0', which is absent when the admin names the alias.
        AggregateResult ar = (AggregateResult) rows[0];
        Map<String, Object> populated = ar.getPopulatedFieldsAsMap();
        Object val = populated.isEmpty() ? null : populated.values()[0];
        if (val == null) {
          return buildUnableResult(
            rule,
            'INVALID_SOQL_TEMPLATE',
            'Applicability SOQL aggregate returned no value. Ensure the SELECT clause contains a valid aggregate function such as COUNT(Id).'
          );
        }
        // SCAN-09: an aggregate value that is not a whole number (or overflows
        // Integer) would throw an uncaught TypeException; surface it as a config
        // error instead so the check reports UNABLE rather than ERROR.
        try {
          count = Integer.valueOf(String.valueOf(val));
        } catch (Exception convEx) {
          return buildUnableResult(
            rule,
            'INVALID_SOQL_TEMPLATE',
            'Applicability SOQL aggregate value could not be read as a whole number. Use COUNT(Id) so the result is an integer.'
          );
        }
      } else {
        return buildUnableResult(
          rule,
          'INVALID_SOQL_TEMPLATE',
          'Applicability SOQL did not return one aggregate COUNT value.'
        );
      }

      Boolean applies = applyApplicabilityComparator(
        rule.CountOperator__c,
        count,
        (Integer) rule.CountThreshold__c
      );

      if (applies == null) {
        return buildUnableResult(
          rule,
          'INVALID_COMPARATOR',
          'Applicability Comparator "' +
            rule.CountOperator__c +
            '" is not recognized.'
        );
      }
      if (!applies) {
        return buildSkippedResult(rule);
      }
      return null;
    } catch (System.QueryException qex) {
      return buildUnableResult(rule, 'INVALID_SOQL_TEMPLATE', qex.getMessage());
    } catch (RecordHealthCheckEvaluatorException eex) {
      return buildUnableResult(rule, eex.reasonCode, eex.getMessage());
    } catch (RecordHealthCheckSoqlTemplate.TemplateException tex) {
      return buildUnableResult(rule, tex.reasonCode, tex.getMessage());
    } catch (Exception ex) {
      return buildUnableResult(rule, 'UNABLE_TO_EVALUATE', ex.getMessage());
    }
  }

  @TestVisible
  private Boolean applyApplicabilityComparator(
    String comparator,
    Integer count,
    Integer threshold
  ) {
    if (comparator == 'Equals')
      return count == threshold;
    if (comparator == 'NotEquals')
      return count != threshold;
    if (comparator == 'GreaterThan')
      return count > threshold;
    if (comparator == 'GreaterThanOrEqual')
      return count >= threshold;
    if (comparator == 'LessThan')
      return count < threshold;
    if (comparator == 'LessThanOrEqual')
      return count <= threshold;
    return null;
  }

  // ─── Record loading ───────────────────────────────────────────────────────

  @TestVisible
  private SObject loadRecord(Id recordId, Record_Health_Check_Rule__mdt rule) {
    // WITH USER_MODE enforces FLS and CRUD for the running user.
    // Exceptions (inaccessible fields, object access denied) propagate to
    // doEvaluate, which maps them to RECORD_NOT_ACCESSIBLE.
    String objectName = recordId.getSObjectType().getDescribe().getName();
    Set<String> fields = collectRecordFields(rule, recordId.getSObjectType());
    List<String> fieldList = new List<String>(fields);
    fieldList.sort();

    String soql =
      'SELECT ' +
      String.join(fieldList, ', ') +
      ' FROM ' +
      objectName +
      ' WHERE Id = :recordId WITH USER_MODE LIMIT 1';
    List<SObject> rows = Database.query(soql);
    return rows.isEmpty() ? null : rows[0];
  }

  @TestVisible
  private Set<String> collectRecordFields(
    Record_Health_Check_Rule__mdt rule,
    Schema.SObjectType objectType
  ) {
    Set<String> fields = new Set<String>{ 'Id' };

    // Invalid display-message tokens are intentionally ignored: message rendering
    // turns them into blanks and they must never make record loading fail.
    addMergeFields(fields, objectType, rule.MessageWhenFailed__c);
    addMergeFields(fields, objectType, rule.MessageWhenCannotRun__c);
    addMergeFields(fields, objectType, rule.DataQuery__c);
    addMergeFields(fields, objectType, rule.CompareToQuery__c);
    addMergeFields(fields, objectType, rule.RunWhenCountQuery__c);

    if (rule.CheckMethod__c == 'Formula') {
      addFormulaFields(fields, objectType, rule.PassFailFormula__c);
    }
    if (rule.CheckMethod__c == 'Query') {
      // List checks read the scalar from ValueToTest__c; RecordFormula compares to RecordFormulaValue__c.
      addFormulaFields(fields, objectType, rule.ValueToTest__c);
      addFormulaFields(fields, objectType, rule.RecordFormulaValue__c);
    }
    // CompareTwoQueries: both sides are SOQL — merge tokens already handled above
    if (rule.RunThisCheckWhen__c == 'Formula') {
      addFormulaFields(fields, objectType, rule.RunWhenFormula__c);
    }

    return fields;
  }

  private void addMergeFields(
    Set<String> fields,
    Schema.SObjectType objectType,
    String template
  ) {
    if (String.isBlank(template)) {
      return;
    }

    Matcher matcher = PATTERN_TOKEN.matcher(template);
    while (matcher.find()) {
      addReadableField(fields, objectType, matcher.group(1));
    }
  }

  private void addFormulaFields(
    Set<String> fields,
    Schema.SObjectType objectType,
    String formula
  ) {
    if (String.isBlank(formula)) {
      return;
    }

    Set<String> formulaWords = new Set<String>{
      'ABS',
      'AND',
      'BEGINS',
      'BLANKVALUE',
      'BR',
      'CASE',
      'CEILING',
      'CONTAINS',
      'CURRENCYRATE',
      'DATE',
      'DATETIMEVALUE',
      'DATEVALUE',
      'DAY',
      'EXP',
      'FALSE',
      'FIND',
      'FLOOR',
      'HTMLENCODE',
      'HOUR',
      'HYPERLINK',
      'IF',
      'IMAGE',
      'INCLUDES',
      'ISBLANK',
      'ISNULL',
      'ISPICKVAL',
      'JSENCODE',
      'JSINHTMLENCODE',
      'LEFT',
      'LEN',
      'LN',
      'LOG',
      'LOWER',
      'MAX',
      'MID',
      'MIN',
      'MOD',
      'MONTH',
      'NOT',
      'NOW',
      'NULL',
      'NULLVALUE',
      'OR',
      'PI',
      'POWER',
      'REGEX',
      'RIGHT',
      'ROUND',
      'SQRT',
      'SUBSTITUTE',
      'TEXT',
      'TODAY',
      'TRIM',
      'TRUE',
      'UPPER',
      'URLENCODE',
      'VALUE',
      'WEEKDAY',
      'YEAR'
    };

    // Formula string literals use double quotes. Mask them before scanning so a
    // value such as "example.com" is never mistaken for a relationship path.
    String scannableFormula = maskFormulaStringLiterals(formula);

    // First pass: capture relationship traversal paths whole (e.g. Parent.ShippingCity).
    // These must be added as a dotted path to the SELECT so SOQL and getSObject() traversal
    // both work. A word-only scan would split them into non-existent bare field names.
    Matcher dotMatcher = PATTERN_DOT_PATH.matcher(scannableFormula);
    while (dotMatcher.find()) {
      addReadableField(fields, objectType, dotMatcher.group(1));
    }

    // Second pass: single-segment field names (relationship components are harmlessly
    // re-attempted here; addReadableField skips any name not found in the fieldMap).
    Matcher matcher = PATTERN_WORD.matcher(scannableFormula);
    while (matcher.find()) {
      String word = matcher.group(0);
      if (!formulaWords.contains(word.toUpperCase())) {
        addReadableField(fields, objectType, word);
      }
    }
  }

  @TestVisible
  private String maskFormulaStringLiterals(String formula) {
    String masked = '';
    Boolean inQuote = false;
    for (Integer i = 0; i < formula.length(); i++) {
      String ch = formula.substring(i, i + 1);
      if (ch == '"' && (i == 0 || formula.substring(i - 1, i) != '\\')) {
        inQuote = !inQuote;
        masked += '"';
      } else {
        masked += inQuote ? ' ' : ch;
      }
    }
    return masked;
  }

  @TestVisible
  private void addReadableField(
    Set<String> fields,
    Schema.SObjectType objectType,
    String fieldPath
  ) {
    if (String.isBlank(fieldPath)) {
      return;
    }
    List<String> parts = fieldPath.split('\\.');
    Schema.SObjectType currentType = objectType;
    for (Integer i = 0; i < parts.size(); i++) {
      Map<String, Schema.SObjectField> currentFields = currentType.getDescribe()
        .fields.getMap();
      if (i == parts.size() - 1) {
        Schema.SObjectField terminal = currentFields.get(parts[i]);
        if (terminal != null && terminal.getDescribe().isAccessible()) {
          fields.add(fieldPath);
        }
        return;
      }

      Schema.SObjectField relationshipField;
      for (Schema.SObjectField candidate : currentFields.values()) {
        Schema.DescribeFieldResult description = candidate.getDescribe();
        if (
          description.getRelationshipName() != null &&
          description.getRelationshipName().equalsIgnoreCase(parts[i])
        ) {
          relationshipField = candidate;
          break;
        }
      }
      if (
        relationshipField == null ||
        !relationshipField.getDescribe().isAccessible()
      ) {
        return;
      }
      List<Schema.SObjectType> referenceTypes = relationshipField
        .getDescribe()
        .getReferenceTo();
      if (referenceTypes.isEmpty()) {
        return;
      }
      currentType = referenceTypes[0];
    }
  }

  @TestVisible
  private void addReadableField(
    Set<String> fields,
    Map<String, Schema.SObjectField> fieldMap,
    String fieldName
  ) {
    if (String.isBlank(fieldName)) {
      return;
    }
    if (fieldName.contains('.'))
      return;
    if (
      fieldMap.containsKey(fieldName) &&
      fieldMap.get(fieldName).getDescribe().isAccessible()
    ) {
      fields.add(fieldName);
    }
  }

  // ─── Result builders ──────────────────────────────────────────────────────

  @TestVisible
  private RecordHealthCheckResult buildSkippedResult(
    Record_Health_Check_Rule__mdt rule
  ) {
    RecordHealthCheckResult r = new RecordHealthCheckResult();
    r.checkDeveloperName = rule.DeveloperName;
    r.label = rule.CheckName__c;
    r.priority = rule.RunOrder__c;
    r.evaluatorType = rule.CheckMethod__c;
    r.status = 'SKIPPED';
    r.reasonCode = 'APPLICABILITY_NOT_MET';
    if (rule.RunThisCheckWhen__c == 'Formula') {
      r.message = 'This check does not apply because its formula applicability condition evaluated to false.';
    } else if (rule.RunThisCheckWhen__c == 'SOQL') {
      r.message = 'This check does not apply because its SOQL applicability query did not meet the configured threshold.';
    } else {
      r.message = 'This check does not apply to the current record.';
    }
    return r;
  }

  /**
   * Resolves {!FieldName} merge tokens in a result's user-facing message so a
   * token like {!Name} never reaches the UI. Applies to every check type because
   * it runs on the final result rather than per-evaluator. Framework messages
   * carry no tokens (no-op) and PASS rows usually have no message. A bad token
   * collapses to empty string and never changes status (S55). Requires the base
   * record to be loaded; callers invoke it only after step 3.
   */
  private void resolveResultMessage(
    RecordHealthCheckResult result,
    SObject record
  ) {
    if (result != null && String.isNotBlank(result.message)) {
      result.message = formulaEvaluator.resolveMergeFields(
        result.message,
        record
      );
    }
  }

  @TestVisible
  private RecordHealthCheckResult buildUnableResult(
    Record_Health_Check_Rule__mdt rule,
    String reasonCode,
    String detail
  ) {
    RecordHealthCheckResult r = new RecordHealthCheckResult();
    r.checkDeveloperName = rule.DeveloperName;
    r.label = rule.CheckName__c;
    r.priority = rule.RunOrder__c;
    r.evaluatorType = rule.CheckMethod__c;
    r.status = 'UNABLE_TO_EVALUATE';
    r.reasonCode = reasonCode;
    r.detailMessage = detail;
    r.message = String.isNotBlank(rule.MessageWhenCannotRun__c)
      ? rule.MessageWhenCannotRun__c
      : 'This check could not be evaluated. Contact your administrator.';
    return r;
  }
}
