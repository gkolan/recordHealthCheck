    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} is missing a phone number on the account record.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
