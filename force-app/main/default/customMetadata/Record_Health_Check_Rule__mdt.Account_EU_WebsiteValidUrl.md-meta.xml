<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>EU - Website Valid URL</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Everyday_Use_Cases</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Website Looks Like a Valid URL</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Format check beyond presence: REGEX in Formula ensures Website resembles http(s)://host.tld. Contrast Account_DQ_Website (presence only).</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>PassFailFormula__c</field>
        <value
      xsi:type="xsd:string"
    >AND(NOT(ISBLANK(Website)), REGEX(Website, &quot;https?://.+\\..+&quot;))</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} website does not look like a valid URL. Use a full http:// or https:// address.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate the website format. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value xsi:type="xsd:string">NOT(ISBLANK(Website))</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">75</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
