<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Comp - Active Signed Contract</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Compliance_Audit</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Has an Active Signed Contract</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Contract compliance: customer accounts must have an Activated, signed, non-expired Contract. EmptyResultBehavior=Fail when none qualify.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Id FROM Contract WHERE AccountId = {!Id} AND Status = &apos;Activated&apos; AND CustomerSignedDate != null AND EndDate &gt;= TODAY</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">Id</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AnyRowPasses</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">IsNotBlank</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Fail</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} is a customer with no active, signed contract on file. Verify the agreement before continued service or billing.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not verify contracts on this account. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value
      xsi:type="xsd:string"
    >ISPICKVAL(Type, &quot;Customer&quot;)</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">40</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
