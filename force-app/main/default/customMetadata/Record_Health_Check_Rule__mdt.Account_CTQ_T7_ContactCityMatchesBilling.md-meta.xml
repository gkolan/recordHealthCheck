<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>CTQ - Contact City Matches Billing</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Compare_Queries</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >Primary Contact Mailing City Matches Account Billing City</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Compares a field value from two independent single-record queries. The oldest contact&apos;s mailing city must match the account&apos;s billing city. SOQL applicability gate skips the check when no contacts exist.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">CompareTwoQueries</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT MailingCity FROM Contact WHERE AccountId = {!Id} ORDER BY CreatedDate ASC LIMIT 1</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">MailingCity</value>
    </values>
    <values>
        <field>CompareToQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT BillingCity FROM Account WHERE Id = {!Id} LIMIT 1</value>
    </values>
    <values>
        <field>CompareToField__c</field>
        <value xsi:type="xsd:string">BillingCity</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">OneResult</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">Equals</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">SkipRecordsWithMissingValue</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Info</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name}&apos;s primary contact mailing city does not match the account billing city. Verify the address alignment.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not compare contact city against billing city. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">SOQL</value>
    </values>
    <values>
        <field>RunWhenCountQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>CountOperator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CountThreshold__c</field>
        <value xsi:type="xsd:double">0</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">20</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
