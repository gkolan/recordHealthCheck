<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Adv - Billing State In Contacts</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Advanced_Checks</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >Billing State Appears in Contact Mailing States</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >ListContainsAny: primary value comes from Value To Test as the account BillingState scalar, not from DataQuery__c. The comparison side is the list of distinct contact mailing states. SOQL applicability gate skips when no contacts have a mailing state.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>ValueToTest__c</field>
        <value xsi:type="xsd:string">BillingState</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">CompareAsLists</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">ListContainsAny</value>
    </values>
    <values>
        <field>CompareToQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT MailingState FROM Contact WHERE AccountId = {!Id} AND MailingState != null</value>
    </values>
    <values>
        <field>CompareToField__c</field>
        <value xsi:type="xsd:string">MailingState</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Skip</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Info</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name}&apos;s billing state does not match any contact mailing state. Verify that your billing address aligns with where your contacts are located.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not compare billing state against contact mailing states. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">SOQL</value>
    </values>
    <values>
        <field>RunWhenCountQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM Contact WHERE AccountId = {!Id} AND MailingState != null</value>
    </values>
    <values>
        <field>CountOperator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CountThreshold__c</field>
        <value xsi:type="xsd:double">0</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">60</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
