<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>FC - Conditional Applicability</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Formula_Coverage</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >Customer Account Has Annual Revenue Set</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Formula check with ISPICKVAL applicability gate — the rule only runs for Customer accounts. Non-Customer accounts receive SKIPPED. Demonstrates the pattern where applicability and the check itself use different field combinations: applicability targets Type, the formula targets AnnualRevenue.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>PassFailFormula__c</field>
        <value xsi:type="xsd:string">NOT(ISBLANK(AnnualRevenue))</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} is a Customer account but has no Annual Revenue set. Annual Revenue is required for customer segmentation and renewal forecasting.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value xsi:type="xsd:string">ISPICKVAL(Type, "Customer")</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">60</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
