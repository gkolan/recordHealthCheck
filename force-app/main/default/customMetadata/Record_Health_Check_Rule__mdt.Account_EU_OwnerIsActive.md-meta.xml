<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>EU - Account Owner Is Active</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Everyday_Use_Cases</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Account Owner Is an Active User</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Everyday data hygiene: the running account&apos;s owner must be an active User. Query User with OwnerId merge token; COUNT() OneResult Equals 1.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM User WHERE Id = {!OwnerId} AND IsActive = true</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">OneResult</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">Equals</value>
    </values>
    <values>
        <field>CompareAgainst__c</field>
        <value xsi:type="xsd:string">FixedValue</value>
    </values>
    <values>
        <field>FixedValue__c</field>
        <value xsi:type="xsd:string">1</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} is owned by an inactive user. Reassign the account to an active owner.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not verify whether the account owner is active. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Always</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">70</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
