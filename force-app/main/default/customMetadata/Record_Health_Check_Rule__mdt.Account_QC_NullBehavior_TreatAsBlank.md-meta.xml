<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>QC - NullBehavior TreatMissingAsBlank</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Query_Coverage</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >All Contacts Have Same Mailing State as Account Billing State</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >NullBehavior=TreatMissingAsBlank: a null MailingState is treated as an empty string. Combined with RecordFormula comparison resolving to BillingState: if BillingState is also blank, a contact with null MailingState will match (null == blank == blank). Use this when your data model treats null and empty-string as equivalent. Contrast with MissingMeansNoMatch (Account_QC_ERB_Pass_NullNoMatch), where null explicitly fails the comparison. EmptyResultBehavior=Pass: accounts with no contacts vacuously satisfy this check.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT MailingState FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">MailingState</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AllRowsPass</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">Equals</value>
    </values>
    <values>
        <field>CompareAgainst__c</field>
        <value xsi:type="xsd:string">RecordFormula</value>
    </values>
    <values>
        <field>RecordFormulaValue__c</field>
        <value xsi:type="xsd:string">BillingState</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Pass</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">TreatMissingAsBlank</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Info</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has one or more contacts whose mailing state does not match the account billing state. Verify the address alignment.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Always</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">120</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
