<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>QC - List Not Contains + ERB UTE</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Query_Coverage</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >Industry Is Not Shared With Other Accounts</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >ListDoesNotContainAny comparator sample (Info severity — not a production data-quality bar). The scalar Industry must not appear in the comparison list of other accounts&apos; industries. Fails often in populated orgs; use for pattern reference only.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>ValueToTest__c</field>
        <value xsi:type="xsd:string">Industry</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">CompareAsLists</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">ListDoesNotContainAny</value>
    </values>
    <values>
        <field>CompareToQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Industry FROM Account WHERE Id != {!Id} AND Industry != null</value>
    </values>
    <values>
        <field>CompareToField__c</field>
        <value xsi:type="xsd:string">Industry</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Pass</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Info</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} shares its industry with at least one other account. This sample rule is illustrative — in most orgs many accounts share an industry. Copy the ListDoesNotContainAny pattern, not this threshold.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not compare this account&apos;s industry against other accounts. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value xsi:type="xsd:string">NOT(ISBLANK(TEXT(Industry)))</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">100</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
