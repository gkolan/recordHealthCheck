<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Comp - Country Not Restricted</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Compliance_Audit</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Billing Country Not Restricted</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Sanctions screening: BillingCountry must not appear in Restricted_Country__c reference list. Requires custom object Restricted_Country__c with Name and Active__c.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>ValueToTest__c</field>
        <value xsi:type="xsd:string">BillingCountry</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">CompareAsLists</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">ListDoesNotContainAny</value>
    </values>
    <values>
        <field>CompareToQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Name FROM Restricted_Country__c WHERE Active__c = true</value>
    </values>
    <values>
        <field>CompareToField__c</field>
        <value xsi:type="xsd:string">Name</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Pass</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has a billing country on the restricted/sanctioned list. Do not transact until compliance clears this account.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not screen billing country — confirm Restricted_Country__c exists. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value xsi:type="xsd:string">NOT(ISBLANK(BillingCountry))</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">80</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
