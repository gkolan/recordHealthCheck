<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Comp - High Risk Reviewed</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Compliance_Audit</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >High-Risk Account Reviewed in Last 12 Months</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >AML periodic review: high-risk accounts need Last_Compliance_Review_Date__c within 365 days. Custom fields — replace with your org&apos;s risk model.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>PassFailFormula__c</field>
        <value
      xsi:type="xsd:string"
    >AND(NOT(ISBLANK(Last_Compliance_Review_Date__c)), (TODAY() - Last_Compliance_Review_Date__c) &lt; 365)</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} is high-risk and has not had a compliance review in over 12 months. Schedule a review now.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate compliance review date — confirm custom risk fields exist. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Formula</value>
    </values>
    <values>
        <field>RunWhenFormula__c</field>
        <value
      xsi:type="xsd:string"
    >ISPICKVAL(Risk_Rating__c, &quot;High&quot;)</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">70</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
