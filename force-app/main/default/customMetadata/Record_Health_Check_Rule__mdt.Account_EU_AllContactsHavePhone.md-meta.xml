<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>EU - All Contacts Have Phone</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Everyday_Use_Cases</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">All Contacts Have a Phone Number</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Everyday pattern: every child row must pass. Query + AllRowsPass + IsNotBlank on Contact.Phone. EmptyResultBehavior=Pass skips the rule when there are no contacts (vacuous pass). NullBehavior=MissingMeansNoMatch treats blank phone as a failure. Not ListContainsAll — that comparator is for list-vs-list CompareTwoQueries only.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Phone FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">Phone</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AllRowsPass</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">IsNotBlank</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Pass</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">MissingMeansNoMatch</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has one or more contacts without a phone number. Every contact should be reachable by phone.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate this health check. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Always</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">10</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
