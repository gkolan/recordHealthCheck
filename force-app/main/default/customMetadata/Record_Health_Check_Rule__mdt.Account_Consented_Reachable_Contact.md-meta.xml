<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Comp - Consented Reachable Contact</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Compliance_Audit</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Has a Consented, Reachable Contact</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Marketing consent audit: at least one contact with email and HasOptedOutOfEmail=false. SOQL applicability skips accounts with no contacts.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Id FROM Contact WHERE AccountId = {!Id} AND Email != null AND HasOptedOutOfEmail = false</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">Id</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AnyRowPasses</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">IsNotBlank</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Skip</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has contacts, but none have a valid email with marketing consent. Do not include this account in email campaigns.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not verify marketing consent on contacts. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">SOQL</value>
    </values>
    <values>
        <field>RunWhenCountQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>CountOperator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CountThreshold__c</field>
        <value xsi:type="xsd:double">0</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">30</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
