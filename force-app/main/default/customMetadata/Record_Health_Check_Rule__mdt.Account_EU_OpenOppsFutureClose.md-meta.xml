<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>EU - All Open Opps Future Close Date</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Everyday_Use_Cases</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >All Open Opportunities Have a Future Close Date</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Everyday pipeline hygiene: every open opportunity CloseDate must be today or later. AllRowsPass + GreaterThanOrEqual + RecordFormula TODAY(). EmptyResultBehavior=Skip when no open opps. Contrast with Account_Adv_AllOppsHaveAmount (numeric field on every row).</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT CloseDate FROM Opportunity WHERE AccountId = {!Id} AND IsClosed = false</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">CloseDate</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AllRowsPass</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">GreaterThanOrEqual</value>
    </values>
    <values>
        <field>CompareAgainst__c</field>
        <value xsi:type="xsd:string">RecordFormula</value>
    </values>
    <values>
        <field>RecordFormulaValue__c</field>
        <value xsi:type="xsd:string">TODAY()</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Skip</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">SkipRecordsWithMissingValue</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has one or more open opportunities with a close date in the past. Update close dates to reflect realistic pipeline timing.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate this health check. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">SOQL</value>
    </values>
    <values>
        <field>RunWhenCountQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM Opportunity WHERE AccountId = {!Id} AND IsClosed = false</value>
    </values>
    <values>
        <field>CountOperator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CountThreshold__c</field>
        <value xsi:type="xsd:double">0</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">60</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
