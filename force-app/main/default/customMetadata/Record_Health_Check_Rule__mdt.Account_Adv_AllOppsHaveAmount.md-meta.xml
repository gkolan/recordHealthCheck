<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>Adv - All Open Opps Have an Amount</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Advanced_Checks</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value
      xsi:type="xsd:string"
    >All Open Opportunities Have a Positive Amount</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >AllRowsPass with FixedValue comparison. Every open opportunity must have Amount greater than zero. EmptyResultBehavior=Skip means the check is skipped when there are no open opportunities, avoiding a vacuous-truth false positive. NullBehavior skips rows where Amount is null instead of treating them as failing.</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Amount FROM Opportunity WHERE AccountId = {!Id} AND IsClosed = false</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">Amount</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AllRowsPass</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CompareAgainst__c</field>
        <value xsi:type="xsd:string">FixedValue</value>
    </values>
    <values>
        <field>FixedValue__c</field>
        <value xsi:type="xsd:string">0</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Skip</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">SkipRecordsWithMissingValue</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Warning</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has one or more open opportunities with no amount. Every open opportunity must have a positive amount for accurate forecasting.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate opportunity amounts. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">Always</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">50</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
