<?xml version="1.0" encoding="UTF-8" ?>
<CustomMetadata
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
>
    <label>EU - At Least One Contact Has Email</label>
    <protected>false</protected>
    <values>
        <field>Record_Health_Check_Set__c</field>
        <value xsi:type="xsd:string">Account_Everyday_Use_Cases</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">At Least One Contact Has Email</value>
    </values>
    <values>
        <field>Tooltip__c</field>
        <value
      xsi:type="xsd:string"
    >Everyday pattern: only one row needs to pass. Query + AnyRowPasses + IsNotBlank. EmptyResultBehavior=Skip when no contacts exist. Contrast with Account_EU_AllContactsHaveEmail where every row must pass. Alternative: COUNT() with Email != null in WHERE (see Account_Adv_ContactHasEmail).</value>
    </values>
    <values>
        <field>CheckMethod__c</field>
        <value xsi:type="xsd:string">Query</value>
    </values>
    <values>
        <field>DataQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT Email FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>FieldToRead__c</field>
        <value xsi:type="xsd:string">Email</value>
    </values>
    <values>
        <field>WhenMultipleRows__c</field>
        <value xsi:type="xsd:string">AnyRowPasses</value>
    </values>
    <values>
        <field>Operator__c</field>
        <value xsi:type="xsd:string">IsNotBlank</value>
    </values>
    <values>
        <field>WhenZeroRows__c</field>
        <value xsi:type="xsd:string">Skip</value>
    </values>
    <values>
        <field>WhenValueIsEmpty__c</field>
        <value xsi:type="xsd:string">MissingMeansNoMatch</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Error</value>
    </values>
    <values>
        <field>MessageWhenFailed__c</field>
        <value
      xsi:type="xsd:string"
    >{!Name} has contacts but none have an email address on file.</value>
    </values>
    <values>
        <field>MessageWhenCannotRun__c</field>
        <value
      xsi:type="xsd:string"
    >Could not evaluate this health check. Contact your administrator.</value>
    </values>
    <values>
        <field>RunThisCheckWhen__c</field>
        <value xsi:type="xsd:string">SOQL</value>
    </values>
    <values>
        <field>RunWhenCountQuery__c</field>
        <value
      xsi:type="xsd:string"
    >SELECT COUNT() FROM Contact WHERE AccountId = {!Id}</value>
    </values>
    <values>
        <field>CountOperator__c</field>
        <value xsi:type="xsd:string">GreaterThan</value>
    </values>
    <values>
        <field>CountThreshold__c</field>
        <value xsi:type="xsd:double">0</value>
    </values>
    <values>
        <field>RunOrder__c</field>
        <value xsi:type="xsd:double">40</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
