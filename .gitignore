# This file is used for Git repositories to specify intentionally untracked files that Git should ignore. 
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json
.claude/
.playwright-mcp/

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# ApexPMD cache
.pmdCache

# Eslint cache
.eslintcache

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Local environment variables
.env

# Internal / local-only files — kept on your machine, never published.
# Remove an entry below if you decide you DO want it in the public repo.
.backups/
tasks/
slides_build/
*.pptx
project-homepage.html
project-homepage copy.html
PUBLISHING.md

# Standalone interactive HTML pages (not part of the published docs)
docs/interactive/

# Stray screenshots / build images (not referenced by docs)
build-record-health-check-mobile.png

# Engineering audit reports (living backlog is in tasks/)
docs/audits/

# Maintainer execution plans and deferred-feature archives (local only)
docs/enhancements/
force-app/deferred/

# Dev iteration notes superseded by design spec + CHANGELOG
docs/reference/record-health-check-ui-changes-2026-06.md

# Engineering hardening tracker (backlog, effort sizing, status — maintainer only)
docs/reference/code-quality-and-hardening-guide.md

# CI / IDE artifacts
code-analyzer.html
.cursor/
.vscode/
*.tgz

# Doc-template scaffolding / boilerplate — not published with the project.
# (Note: .github/ISSUE_TEMPLATE/ and pull_request_template.md are functional
#  GitHub config and are intentionally NOT ignored.)
templates/
docs/_templates/
**/_TEMPLATE.*

# Maintainer doc-generation / authoring tooling (one-off Python scripts).
# Kept local; the .apex/.soql helper scripts under scripts/ stay in the repo.
scripts/**/*.py

# Python Salesforce Functions
**/__pycache__/
**/.venv/
**/venv/
